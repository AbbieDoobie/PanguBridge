<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="WindowBackground" Color="#F3F3F3" />
    <SolidColorBrush x:Key="PanelBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlBackground" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlBackgroundHover" Color="#E5E5E5" />
    <SolidColorBrush x:Key="Foreground" Color="#1E1E1E" />
    <SolidColorBrush x:Key="SubtleForeground" Color="#5A5A5A" />
    <SolidColorBrush x:Key="BorderBrush" Color="#DDDDDD" />
    <SolidColorBrush x:Key="AccentBrush" Color="#0067C0" />
</ResourceDictionary>
