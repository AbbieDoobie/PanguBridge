    <SolidColorBrush x:Key="PanelBackground" Color="#252526" />
    <SolidColorBrush x:Key="ControlBackground" Color="#3C3C3C" />
    <SolidColorBrush x:Key="ControlBackgroundHover" Color="#4A4A4A" />
    <SolidColorBrush x:Key="Foreground" Color="#E6E6E6" />
