<Application x:Class="PanguBridge.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <!-- Looks like a label but supports text selection/copy (plain TextBlock can't).
             Used throughout for any descriptive or diagnostic text, so error messages etc.
             can be copied out of the GUI. -->
        <!-- Assigning Style="{StaticResource SelectableText}" replaces the implicit
             ControlStyles.xaml TextBox style entirely rather than merging with it, so this
             needs its own Foreground setter - without one it fell back to Control's default
             black, which is how black text was sneaking into the dark theme. -->
        <Style x:Key="SelectableText" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Foreground}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="IsReadOnlyCaretVisible" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        </Style>

        <tb:TaskbarIcon x:Key="TrayIcon"
                         ToolTipText="Pangu Bridge"
                         TrayMouseDoubleClick="TrayIcon_OnDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <!-- Background set locally (not via a Style) so this stays the plain default
                     WPF context menu - no custom template, no theme-following. It's needed
                     because .NET 8 WPF's default popup chrome on Windows 11 is semi-
                     transparent (Mica-style rounded corners) unless given an opaque
                     background; SystemColors.MenuBrush (rather than hardcoded White) keeps
                     this matching whatever the user's actual OS menu color is.

                     Each Header below is an explicit TextBlock with its own local Foreground,
                     rather than a plain string - plain-string headers get wrapped in an
                     auto-generated TextBlock that the app-wide implicit TextBlock style (used
                     for dark mode everywhere else) still styles regardless of what Foreground
                     is set on the ContextMenu/MenuItem, because a Style setter beats an
                     inherited value in WPF's property precedence. An explicit local Foreground
                     on this specific TextBlock beats the Style setter and actually wins. -->
                <ContextMenu Background="{x:Static SystemColors.MenuBrush}">
                    <MenuItem Click="TrayIcon_OnOpenClick">
                        <MenuItem.Header>
                            <TextBlock Text="Open" Foreground="{x:Static SystemColors.MenuTextBrush}" />
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator />
                    <MenuItem Click="TrayIcon_OnExitClick">
                        <MenuItem.Header>
                            <TextBlock Text="Exit" Foreground="{x:Static SystemColors.MenuTextBrush}" />
                        </MenuItem.Header>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
